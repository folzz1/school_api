    {
      "name": "createstudent",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 201 Created\", function () {\r",
              "  pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "const json = pm.response.json();\r",
              "\r",
              "pm.test(\"Student id exists\", function () {\r",
              "  pm.expect(json.id).to.exist;\r",
              "});\r",
              "\r",
              "const token = pm.response.headers.get(\"x-auth-token\");\r",
              "\r",
              "pm.test(\"X-Auth-Token exists\", function () {\r",
              "  pm.expect(token).to.exist;\r",
              "});\r",
              "\r",
              "pm.collectionVariables.set(\"student_id\", json.id);\r",
              "pm.collectionVariables.set(\"auth_token\", token);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
